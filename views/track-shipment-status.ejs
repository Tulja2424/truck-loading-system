<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shipment Status</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-b from-gray-100 to-white min-h-screen p-6">

    <div class="max-w-4xl mx-auto">

        <!-- Heading -->
        <div class="flex items-center justify-between mb-3 border-b-2 border-blue-200 pb-2">
            <h3 class="text-2xl font-semibold text-blue-700">
                <%= status.charAt(0).toUpperCase() + status.slice(1) %> Shipment Details
            </h3>

            <button 
                type="button"
                onclick="window.location.href='/track-shipment/<%= warehouse._id %>'"
                class="underline text-grey px-4 py-2 rounded-lg hover:border-black-600 transition"
            >
                Back
            </button>
        </div>

        <!-- No Shipments Found -->
        <% if (requests.length === 0) { %>
            <p class="text-center text-gray-500 mt-10">
                No <%= status %> shipments found.
            </p>
        <% } else { %>

        <!-- Shipments List -->
        <div class="space-y-4">

            <% requests.forEach((request) => { %>

                <div class="bg-white border-l-4 border-blue-600 shadow-sm rounded-md p-5">

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-2 text-gray-700">

                        <p>
                            <span class="font-medium text-black">Shipment ID:</span> 
                            <%= request.shipment_id._id %>
                        </p>

                        <p>
                            <span class="font-medium text-black">Truck ID:</span> 
                            <%= request.truck_id ? request.truck_id._id : 'N/A' %>
                        </p>

                        <p>
                            <span class="font-medium text-black">Dealer ID:</span> 
                            <%= request.dealer_id ? request.dealer_id._id : 'N/A' %>
                        </p>

                        <p>
                            <span class="font-medium text-black">Weight:</span> 
                            <%= request.shipment_id.weight %>
                        </p>

                        <p>
                            <span class="font-medium text-black">Boxes:</span> 
                            <%= request.shipment_id.boxes %>
                        </p>

                        <p>
                            <span class="font-medium text-black">Source:</span> 
                            <%= request.shipment_id.source %>
                        </p>

                        <p>
                            <span class="font-medium text-black">Destination:</span> 
                            <%= request.shipment_id.destination %>
                        </p>

                        <p>
                            <span class="font-medium text-black">Timeline:</span> 
                            <%= request.shipment_id.start ? request.shipment_id.start.toDateString().slice(4,15) : 'N/A' %> -
                            <%= request.shipment_id.end ? request.shipment_id.end.toDateString().slice(4,15) : 'N/A' %>
                        </p>

                    </div>

                    <!-- Button only when status is pending -->
                    <% if (status === "pending") { %>
                        <div class="mt-3">
                            <button
                                type="button"
                                onclick="window.location.href='/shipment-detail/<%= warehouse._id %>/<%= request.shipment_id._id %>'"
                                class="underline text-blue-600 hover:text-blue-800 transition"
                            >
                                Send Request
                            </button>
                        </div>
                    <% } %>

                </div>

            <% }) %>

        </div>

        <% } %>

    </div>

</body>
</html>