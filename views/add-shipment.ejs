<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Shipment</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen">

<div class="max-w-4xl mx-auto p-6">

    <!-- Page Title -->
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-3xl font-semibold text-gray-800">
            Add Shipment Detail
        </h1>

        <button 
            type="button"
            onclick="window.location.href='/profile-warehouse/<%= warehouse._id %>'"
            class="text-gray-600 underline hover:text-black transition"
        >
            Back
        </button>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-xl shadow-md p-6 mb-10">
        <form 
            action="/add-shipment/<%= warehouse._id %>" 
            method="POST"
            class="grid grid-cols-1 md:grid-cols-2 gap-4"
        >

            <input type="number" name="weight" placeholder="Weight" required min="1"
                class="border border-gray-300 rounded-lg px-4 py-2 focus:ring-2">

            <input type="number" name="boxes" placeholder="Boxes" required min="1"
                class="border border-gray-300 rounded-lg px-4 py-2 focus:ring-2">

            <label class="text-sm text-gray-600">From</label>
            <label class="text-sm text-gray-600">To</label>

            <input type="date" name="start" required
                class="border border-gray-300 rounded-lg px-4 py-2 text-gray-500 focus:ring-2">

            <input type="date" name="end" required
                class="border border-gray-300 rounded-lg px-4 py-2 text-gray-500 focus:ring-2">

            <input type="text" name="source" placeholder="Source" required
                pattern="[A-Za-z ]+" title="Source must contain only letters"
                class="border border-gray-300 rounded-lg px-4 py-2 focus:ring-2">

            <input type="text" name="destination" placeholder="Destination" required
                pattern="[A-Za-z ]+" title="Destination must contain only letters"
                class="border border-gray-300 rounded-lg px-4 py-2 focus:ring-2">

            <div class="md:col-span-2 flex justify-end">
                <button type="submit"
                    class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition">
                    Add Shipment
                </button>
            </div>

        </form>
    </div>

    <!-- Shipment List -->
    <% if (requests.length === 0) { %>

        <p class="text-center text-gray-500 mt-10">
            No shipments added yet.
        </p>

    <% } else { %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <% requests.reverse().forEach((request) => { %>
            <% if (request.shipment_id) { %>

            <div class="bg-white rounded-xl shadow-sm p-5 border min-h-[120px] flex flex-col justify-between">

                <div>
                    <h2 class="text-lg font-medium text-gray-800">
                        Shipment ID: <%= request.shipment_id._id %>
                        (<%= request.shipment_id.destination.charAt(0).toUpperCase() + request.shipment_id.destination.slice(1).toLowerCase() %>)
                    </h2>

                    <p class="text-sm text-gray-500 mt-1">
                        <%= request.shipment_id.start
                            ? request.shipment_id.start.toDateString().slice(4, 15)
                            : "N/A" %>
                        –
                        <%= request.shipment_id.end
                            ? request.shipment_id.end.toDateString().slice(4, 15)
                            : "N/A" %>
                    </p>
                </div>

                <div class="text-right mt-3">
                    <button
                        type="button"
                        onclick="window.location.href='/shipment-detail/<%= warehouse._id %>/<%= request.shipment_id._id %>'"
                        class="text-blue-600 hover:text-blue-800 font-medium transition"
                    >
                        See More →
                    </button>
                </div>

            </div>

            <% } %>
        <% }) %>

    </div>

    <% } %>

</div>

</body>
</html>