<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shipment Requests</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen p-6">

<div class="max-w-5xl mx-auto">
        <div class="flex items-center justify-between mb-6">
           <h1 class="text-3xl font-bold text-gray-800 mb-4">📦 Shipment Requests</h1>
            <button type="button" onclick="window.location.href='/profile-dealer/<%= dealerid%>'" class=" px-5 py-1.5 bg-gray-500 rounded-lg text-white font-medium hover:bg-gray-600">Back</button>
        </div>
    <!-- Header -->

    <!-- Empty State -->
    <% if (requests.length === 0) { %>
        <div class="bg-white rounded-xl shadow-md p-10 text-center">
            <p class="text-lg text-gray-500">
                No shipment requests available.
            </p>
        </div>
    <% } else { %>

    <!-- Requests List -->
    <div class="space-y-5">
        <% requests.forEach((request) => { %>

        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-gray-700">

                <p><span class="font-medium text-gray-900">Truck ID:</span> <%= request.truck_id._id %></p>
                <p><span class="font-medium text-gray-900">Shipment ID:</span> <%= request.shipment_id._id %></p>
                
                <p><span class="font-medium text-gray-900">Warehouse ID:</span> <%= request.warehouse_id._id %></p>
                <p><span class="font-medium text-gray-900">Truck Number:</span> <%= request.truck_id.number %></p>
                
                <p><span class="font-medium text-gray-900">Weight:</span> <%= request.shipment_id.weight %> kg</p>
                <p><span class="font-medium text-gray-900">Timeline:</span> <%= request.shipment_id.start ? request.shipment_id.start.toDateString().slice(4,15) : 'N/A' %>-<%= request.shipment_id.end ? request.shipment_id.end.toDateString().slice(4,15) : 'N/A' %></p>
                <p><span class="font-medium text-gray-900">Source:</span> <%= request.shipment_id.source %></p>
                <p><span class="font-medium text-gray-900">Destination:</span> <%= request.shipment_id.destination %></p>

                <p><span class="font-medium text-gray-900">Warehouse:</span>
                    <%= request.warehouse_id.name %>, <%= request.warehouse_id.address %>
                </p>

                <p><span class="font-medium text-gray-900">Contact:</span>
                    <%= request.warehouse_id.contact %>
                </p>

            </div>

            <!-- Actions -->
            <div class="mt-5 flex gap-3">
                <form method="POST" action="/accepted-request">
                    <input type="hidden" name="requestid" value="<%= request._id %>">
                    <button
                        type="submit"
                        class="px-5 py-2 rounded-lg border border-green-600 text-green-600
                               hover:bg-green-600 hover:text-white transition">
                        Accept
                    </button>
                </form>

                <form method="POST" action="/rejected-request">
                    <input type="hidden" name="requestid" value="<%= request._id %>">
                    <button
                        type="submit"
                        class="px-5 py-2 rounded-lg border border-red-600 text-red-600
                               hover:bg-red-600 hover:text-white transition">
                        Reject
                    </button>
                </form>
            </div>

        </div>

        <% }) %>
    </div>

    <% } %>

</div>

</body>
</html>
