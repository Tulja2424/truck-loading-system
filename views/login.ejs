<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LOGIN</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="flex items-center justify-center min-h-screen p-4">
        <div class="w-full max-w-sm p-6">
            <h1 class="text-xl font-bold mb-6 text-center">Login</h1>
            <form method="post" action="/login" class="space-y-3">
                <input placeholder="license" type="text" name="license" class="w-full px-3 py-2 border border-gray-300">
                <input placeholder="password" type="password" name="password" class="w-full px-3 py-2 border border-gray-300">
                <button type="submit" class="w-full py-2 bg-blue-600 text-white font-medium mt-4 hover:bg-blue-700">Login</button>
                <button type="button" onclick="window.location.href='/'" class="w-full py-2 bg-gray-500 text-white font-medium hover:bg-gray-600">Back</button>
            </form>
        </div>
    </div>
</body>
</html>