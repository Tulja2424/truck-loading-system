<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Edit Truck</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen flex items-center justify-center">

<div class="bg-white p-8 rounded-lg shadow w-full max-w-md">

<h2 class="text-2xl font-semibold mb-6 text-center">
Edit Truck
</h2>

<form method="POST" action="/edit-truck/<%= dealerid%>/<%= truckid%>">


<!-- Truck Model -->
<div class="mb-4">
<label class="block mb-1 font-medium">Truck Model</label>
<input 
type="text" 
name="model"
value="<%= truck.model %>"
required
class="w-full border px-3 py-2 rounded bg-gray-100">
</div>

<!-- Registration Number -->
<div class="mb-4">
<label class="block mb-1 font-medium">Registration Number</label>
<input 
type="text" 
name="number"
value="<%= truck.number %>"
required
class="w-full border px-3 py-2 rounded bg-gray-100">
</div>

<!--Capacity-->
<div class="mb-4">
<label class="block mb-1 font-medium">Capacity</label>
<input 
type="number" 
name="capacity"
value="<%= truck.capacity%>"
required
class="w-full border px-3 py-2 rounded">
</div>

<!-- Cost -->
<div class="mb-4">
<label class="block mb-1 font-medium">Cost per KM</label>
<input 
type="number" 
name="cost_km"
value="<%= truck.cost_km %>"
required
class="w-full border px-3 py-2 rounded">
</div>

<!-- CO2 -->
<div class="mb-4">
<label class="block mb-1 font-medium">CO2 Emission</label>
<input 
type="number" 
name="co2_km"
value="<%= truck.co2_km%>"
required
class="w-full border px-3 py-2 rounded">
</div>

<!-- Cities -->
<div class="mb-6">
<label class="block mb-1 font-medium">Cities Covered</label>
<input 
type="text" 
name="cities"
value="<%= truck.cities.join(', ') %>"
placeholder="Delhi, Mumbai, Goa"
required
class="w-full border px-3 py-2 rounded">
</div>

<button
type="submit"
class="w-full bg-blue-600 text-white py-2 rounded hover:bg-blue-700"
>
Update Truck
</button>

</form>

</div>

</body>
</html>