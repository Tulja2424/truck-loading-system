<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dealer Orders</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen flex items-start justify-center p-6">

<div class="w-full max-w-5xl">

    <!-- Header -->
    <div class="max-w-5xl mx-auto px-4">
        <!-- Page Heading -->
        <div class="flex items-center justify-between mb-6">
           <h1 class="text-3xl font-bold text-gray-800 mb-4">🚚 Shipment Orders</h1>
            <button type="button" onclick="window.location.href='/profile-dealer/<%= dealerid %>'" class=" px-5 py-1.5 bg-gray-500 rounded-lg text-white font-medium hover:bg-gray-600">Back</button>
        </div>

    <!-- Empty State -->
    <% if (orders.length === 0) { %>
        <div class="bg-white rounded-xl shadow-md p-10 text-center">
            <p class="text-lg text-gray-500">
                No orders are available at the moment.
            </p>
        </div>
    <% } else { %>

    <!-- Orders List -->
    <div class="space-y-5">
        <% orders.forEach(order => { %>

        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-y-2 text-gray-700">

            <p><span class="font-medium text-gray-900">Truck Number:</span>
               <%= order.truck_id ? order.truck_id.number : 'Not Assigned' %>
            </p>

            <p><span class="font-medium text-gray-900">Shipment ID:</span>
                <%= order.shipment_id ? order.shipment_id._id : 'N/A' %>
            </p>

            <p><span class="font-medium text-gray-900">Weight:</span>
                <%= order.shipment_id ? order.shipment_id.weight + ' kg' : 'N/A' %>
            </p>

            <p><span class="font-medium text-gray-900">Source:</span>
                <%= order.shipment_id ? order.shipment_id.source : 'N/A' %>
            </p>

            <p><span class="font-medium text-gray-900">Destination:</span>
                <%= order.shipment_id ? order.shipment_id.destination : 'N/A' %>
            </p>

            <p><span class="font-medium text-gray-900">Timeline:</span>
                <%= order.shipment_id?.start
            ? new Date(order.shipment_id.start).toDateString().slice(4,15)
            : 'N/A' %>-<%= order.shipment_id?.end
            ? new Date(order.shipment_id.end).toDateString().slice(4,15)
            : 'N/A' %>
            </p>
        </div>


            <!-- Action -->
            <div class="mt-4">
                <% if (order.status === "completed") { %>
                <button disabled
                    class="px-5 py-2 rounded-lg bg-gray-300 text-gray-600 cursor-not-allowed">
                    Completed
                </button>
                <% } else { %>
                    <form action="/completed-order" method="POST">
                    <input type="hidden" name="requestId" value="<%= order._id %>">
                    <input type="hidden" name="dealerid" value="<%= dealerid %>">
                    <button type="submit"
                        class="px-5 py-2 rounded-lg border border-blue-600 text-blue-600
                        hover:bg-blue-600 hover:text-white transition">
                        Mark as Completed
                    </button>
                    </form>
                <% } %>
            </div>


        </div>

        <% }) %>
    </div>

    <% } %>

</div>

</body>
</html>
