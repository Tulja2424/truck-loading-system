<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Truck Loading System - Sign Up</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
    <div class="min-h-screen flex items-center justify-center p-4">
        <div class="w-full max-w-sm">
            <div class="mb-12 text-center">
                <h1 class="text-4xl font-bold text-gray-800 mb-2">Truck Loading System</h1>
                <p class="text-gray-500">Choose your account type</p>
            </div>
            
            <div class="space-y-3">
                <a href="/warehouse-signup" class="block w-full p-4 border-2 border-gray-200 rounded-lg text-center hover:border-blue-500 hover:bg-blue-50 transition duration-200 group">
                    <h3 class="font-semibold text-gray-800 group-hover:text-blue-600">Warehouse User</h3>
                    <p class="text-sm text-gray-500 mt-1">Manage warehouse operations</p>
                </a>
                
                <a href="/dealer-signup" class="block w-full p-4 border-2 border-gray-200 rounded-lg text-center hover:border-green-500 hover:bg-green-50 transition duration-200 group">
                    <h3 class="font-semibold text-gray-800 group-hover:text-green-600">Truck Dealer</h3>
                    <p class="text-sm text-gray-500 mt-1">Register and manage trucks</p>
                </a>
            </div>
        </div>
    </div>
</body>
</html>