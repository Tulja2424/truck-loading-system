<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Track Shipment</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-b from-gray-100 to-white min-h-screen">

    <div class="max-w-5xl mx-auto p-6">
         <div class="flex items-center justify-between mb-3">
        <!-- Page Title -->
        <h1 class="text-2xl font-semibold text-grey-500 mb-6">
            Track Shipments
        </h1>
        <button 
                type="button"
                onclick="window.location.href='/profile-warehouse/<%= warehouse._id %>'"
                class="underline text-grey px-4 py-2 rounded-lg hover:border-black-600 transition"
            >
                Back
        </button>
        </div>
        <!-- Tabs -->
        <div class="flex space-x-4 mb-8">
            <button 
                onclick="window.location.href='/track-shipment/<%= warehouse._id %>/pending'"
                class="px-5 py-2 rounded-full bg-blue-100 text-blue-700 hover:bg-blue-400 transition">
                Pending
            </button>
            <button 
                onclick="window.location.href='/track-shipment/<%= warehouse._id %>/requested'"
                class="px-5 py-2 rounded-full bg-blue-100 text-blue-700 hover:bg-blue-400 transition">
                Requested
            </button>
            <button 
                onclick="window.location.href='/track-shipment/<%= warehouse._id %>/approved'"
                class="px-5 py-2 rounded-full bg-blue-100 text-blue-700 hover:bg-blue-400 transition">
                Approved
            </button>

            <button 
                onclick="window.location.href='/track-shipment/<%= warehouse._id %>/rejected'"
                class="px-5 py-2 rounded-full bg-blue-100 text-blue-700 hover:bg-blue-400 transition">
                Rejected
            </button>

            <button 
                onclick="window.location.href='/track-shipment/<%= warehouse._id %>/completed'"
                class="px-5 py-2 rounded-full bg-blue-100 text-blue-700 hover:bg-blue-400 transition">
                Completed
            </button>
        </div>

        <!-- Content Area -->
        <div class="bg-white p-6 rounded-lg shadow">
            <p class="text-gray-600">
                Select a shipment status to view details.
            </p>
        </div>

    </div>

</body>
</html>
