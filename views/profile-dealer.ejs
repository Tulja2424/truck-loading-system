
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Dealer Profile</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gradient-to-b from-gray-100 to-white text-gray-800">
  <header class="bg-white/80 backdrop-blur-sm border-b">
    <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="h-10 w-10 rounded-md bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold shadow">
          TL
        </div>
        <div>
          <div class="text-sm font-semibold">Truck Loading System</div>
          <div class="text-xs text-gray-500">Dealer dashboard</div>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <a href="/logout/<%= dealer._id %>" class="px-3 py-1.5 bg-red-600 text-white rounded shadow-sm text-sm hover:bg-red-700">Logout</a>
      </div>
    </div>
  </header>

  <main class="max-w-4xl mx-auto p-6">
    <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
      <div class="px-6 py-5 border-b">
        <h1 class="text-2xl font-semibold">Dealer Profile</h1>
      </div>

      <div class="p-6 md:flex md:gap-6">
        <!-- Left: profile -->
        <aside class="md:w-1/3 flex-none">
          <div class="bg-gradient-to-br from-white to-gray-50 p-5 rounded-lg border">
            <div class="flex flex-col items-center">
              <!-- profile image (from public/images/profile-photo.png) -->
              <img src="/images/profile-photo.png" alt="Profile photo" class="h-24 w-24 rounded-full object-cover shadow-inner">
              <h2 class="mt-4 text-lg font-semibold"><%= dealer.name %></h2>
              <p class="text-sm text-gray-500">Truck Dealer</p>

              <div class="mt-4 w-full space-y-2">
                <a href="/dealer-edit/<%= dealer._id %>" class="block text-center px-3 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm">Edit Profile</a>
              </div>
              <div class="mt-5 text-sm text-gray-600 space-y-2">
                  <div>
                    <span class="text-gray-500">License</span>
                    <span class="font-medium"><%= dealer.license %></span>
                  </div>

                  <div>
                    <span class="text-gray-500">Contact</span>
                    <span class="font-medium"><%= dealer.contact %></span>
                  </div>

                  <div class="text-left">
                    <span class="text-gray-500">Address</span>
                    <span class="font-medium "><%= dealer.address %></span>
                  </div>
              </div>

          </div>
        </aside>

        <!-- Right: actions -->
        <section class="mt-6 md:mt-0 md:flex-1">
          <!-- removed Trucks / Requests / Rating cards as requested -->

          <div class="mt-5 bg-white rounded-lg border p-4">
            <div class="flex items-center justify-between">
              <h3 class="text-md font-semibold">Quick Actions</h3> 
            </div>

            <div class="mt-3 grid grid-cols-1 sm:grid-cols-3 gap-3">
              <a href="/add-truck/<%= dealer._id %>" class="flex items-center justify-center gap-2 p-2 rounded-md border hover:shadow-sm transition text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Add Truck
              </a>
              <a href="/view-trucks/<%= dealer._id %>" class="flex items-center justify-center gap-2 p-2 rounded-md border hover:shadow-sm transition text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7h18M3 12h18M3 17h18"/></svg>
                View Trucks
              </a>
              <a href="/dealer-orders/<%= dealer._id %>" class="flex items-center justify-center gap-2 p-2 rounded-md border hover:shadow-sm transition text-sm">
               <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5h6M9 9h6M9 13h6M5 5h.01M5 9h.01M5 13h.01"/></svg>
               Orders
              </a>
              <a href="/truck-request/<%= dealer._id %>" class="flex items-center justify-center gap-2 p-2 rounded-md border hover:shadow-sm transition text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-6a2 2 0 012-2h2l2 2h3"/></svg>
                Requests
              </a>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>
</body>
</html>